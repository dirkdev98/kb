{
  "name": "kb",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kb": "./src/cli.ts"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "dev": "node --disable-warning=ExperimentalWarning --experimental-strip-types src/cli.ts",
    "dev:test": "node --disable-warning=ExperimentalWarning --experimental-strip-types src/test-cli.ts",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:watch": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
